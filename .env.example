# ===== 資料庫 =====
# 本機開發:留空(預設 SQLite local.db)
# 生產(Supabase):Settings → Database → Connection string(建議用 Session pooler)
# 例:postgresql://postgres.xxxx:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# ===== 認證 =====
# none = 本機單人模式(不需登入);supabase = 生產多使用者
AUTH_MODE=none
# Supabase 專案 Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Settings → API → JWT Secret(HS256 驗證;若留空且設了 SUPABASE_URL 會改用 JWKS)
SUPABASE_JWT_SECRET=

# ===== 資料來源 =====
# 強烈建議:到 https://www.tiingo.com 免費註冊取得 API key(含息調整資料,品質最佳)
# 未設定時系統自動退回 yfinance(可用但無保障)
TIINGO_API_KEY=

# ===== 部署 =====
# 你的網域(Caddy 會自動申請 Let's Encrypt 憑證)
DOMAIN=example.com
